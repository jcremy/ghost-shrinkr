{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities granted to the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:app:allow-version",
    "process:allow-exit",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://github.com/*" }
      ]
    }
  ]
}
