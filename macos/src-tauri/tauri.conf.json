{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "GhostShrinkr",
  "version": "1.0.0",
  "identifier": "com.issify.ghostshrinkr",
  "build": {
    "frontendDist": "../../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GhostShrinkr",
        "width": 780,
        "height": 900,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {}
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/jcremy/ghost-shrinkr/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyMThFMjBGNzkwNjM3MQpSV1J4WTVEM0lJNGhETUFuWkF2WnhnOEZqRUVpby8wMVpDNWh3Ukh3T3lkTVJwQ01LVlJweDFPNQo="
    }
  }
}
