{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "GhostShrinkr",
  "version": "1.0.0",
  "identifier": "com.issify.ghostshrinkr",
  "build": {
    "frontendDist": "../../web"
  },
  "app": {
    "windows": [
      {
        "title": "GhostShrinkr",
        "width": 780,
        "height": 900,
        "resizable": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "macOS": {
      "signingIdentity": "-"
    }
  }
}